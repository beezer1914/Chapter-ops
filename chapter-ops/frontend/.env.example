# Frontend environment variables (Vite).
# Copy to .env.local for dev; set these as build-time env vars on Netlify.
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Google reCAPTCHA v3 site key (public — safe to ship in the bundle).
# Pair this with RECAPTCHA_SECRET_KEY on the backend.
# Create a v3 key pair at https://www.google.com/recaptcha/admin
# Leave blank in dev to disable the widget (the backend fails open as well).
VITE_RECAPTCHA_SITE_KEY=
