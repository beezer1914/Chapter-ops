# =============================================================================
# ChapterOps Environment Configuration
# Copy this to backend/.env and fill in your values.
#
# SECURITY NOTES:
#   - NEVER commit your .env file to version control (.gitignore handles this)
#   - In production, use your platform's secret management (e.g., Render/Railway
#     env vars, AWS Secrets Manager, Vault) — never store secrets in files
#   - Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
#   - The app will REFUSE to start in production with default/weak secret keys
# =============================================================================

# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
# IMPORTANT: Replace with a strong random key (at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=postgresql://chapterops:chapterops_dev@localhost:5432/chapterops

# Redis
REDIS_URL=redis://localhost:6379/0

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Connect (find STRIPE_CLIENT_ID in Dashboard → Connect → Settings)
STRIPE_CLIENT_ID=ca_...
STRIPE_CONNECT_REDIRECT_URI=http://localhost:5173/stripe/callback
STRIPE_PLATFORM_FEE_PERCENT=0

# Resend (Email — https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ChapterOps <noreply@yourdomain.com>
# Optional: address users see in Reply-To (e.g. a monitored support inbox)
RESEND_REPLY_TO=support@yourdomain.com

# S3-Compatible Storage (Cloudflare R2 or AWS S3)
S3_BUCKET_NAME=chapterops-files
S3_REGION=auto
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...

# Frontend URL (for CORS — must be your actual domain in production)
FRONTEND_URL=http://localhost:5173

# Backend URL (used by ops agent to generate approval links)
BACKEND_URL=http://localhost:5000

# Ops Agent
FOUNDER_EMAIL=                # Digest and alert destination (your email)
AGENT_ENABLED=true            # Set to false to disable all agent jobs in dev
AGENT_DIGEST_HOUR=7           # Hour (0-23 UTC) to send morning digest
STATUSPAGE_API_KEY=           # Optional — Better Uptime or Statuspage.io API key
STATUSPAGE_PAGE_ID=           # Optional — status page component/page ID

# Google reCAPTCHA v3 (gates /auth/login and /auth/register)
# Create a v3 key pair at https://www.google.com/recaptcha/admin
# Leave RECAPTCHA_SECRET_KEY blank in dev/CI to skip verification.
# The matching site key is set on the frontend as VITE_RECAPTCHA_SITE_KEY.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
